@model IEnumerable<DigitalFormsSystem.Models.DamagedReport>

@{
    ViewData["Title"] = "Damaged Reports";
    var userName = Context.Session.GetString("EmployeeName");
}

<h1>Damaged Reports</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Report</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Control No</th>
            <th>Item</th>
            <th>Date/Time of Incident</th>
            <th>Reported By</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ControlNo</td
                <td>@item.Item</td
                <td>@(item.IncidentDateTime?.ToString("yyyy-MM-dd HH:mm"))</td
                <td>@(item.ReportedByEmployee?.Name)</td
                <td>@item.RequestStatus</td
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Print" asp-route-id="@item.Id" class="btn btn-sm btn-secondary" target="_blank">Print</a>
                    @if (item.RequestStatus == "Draft")
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    }
                </td
            </tr>
        }
    </tbody>
</table>