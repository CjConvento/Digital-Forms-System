@model IEnumerable<DigitalFormsSystem.Models.FixedAssetRequest>

@{
    ViewData["Title"] = "Fixed Asset Requests";
}

<h1>Fixed Asset Requests</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Request</a>
</p>

<!-- rest of the table -->
<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Control No</th>
            <th>Date Requested</th>
            <th>Department</th>
            <th>Section</th>
            <th>Asset Type</th>
            <th>Quantity</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ControlNo</td>
                <td>@item.DateRequested.ToString("yyyy-MM-dd")</td>
                <td>@item.Department</td>
                <td>@item.Section</td>
                <td>@item.AssetType</td>
                <td>@item.Quantity</td>
                <td>@item.RequestStatus</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Print" asp-route-id="@item.Id" class="btn btn-sm btn-secondary" target="_blank">Print</a>
                    @if (item.RequestStatus == "Draft")
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>